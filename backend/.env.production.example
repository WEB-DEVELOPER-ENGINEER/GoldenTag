# Production Environment Configuration
# Copy this file to .env.production and update with actual values

# Database
DATABASE_URL="postgresql://username:password@your-db-host:5432/digital_profile_hub?schema=public&sslmode=require"

# JWT Configuration
JWT_SECRET="CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-AT-LEAST-32-CHARACTERS"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV="production"

# CORS Configuration
CORS_ORIGIN="https://yourdomain.com"

# Frontend URL (for QR code generation and redirects)
FRONTEND_URL="https://yourdomain.com"

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR="/var/www/digital-profile-hub/uploads"

# Storage Provider Configuration
# Options: "local" or "s3"
STORAGE_PROVIDER="local"

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# Security
# Enable HTTPS redirect
FORCE_HTTPS="true"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Logging
LOG_LEVEL="info"
LOG_FILE="/var/log/digital-profile-hub/app.log"
