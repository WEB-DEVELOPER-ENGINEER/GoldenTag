generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  username     String    @unique
  role         Role      @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  profile      Profile?

  @@index([email])
  @@index([username])
}

model Profile {
  id                 String         @id @default(uuid())
  userId             String         @unique
  displayName        String
  bio                String?
  avatarUrl          String?
  backgroundType     BackgroundType @default(COLOR)
  backgroundColor    String?
  backgroundImageUrl String?
  isPublished        Boolean        @default(false)
  viewCount          Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  contacts           Contact[]
  files              File[]
  links              Link[]
  popup              Popup?
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme              Theme?

  @@index([userId])
}

model Theme {
  id             String      @id @default(uuid())
  profileId      String      @unique
  mode           ThemeMode   @default(LIGHT)
  primaryColor   String      @default("#3b82f6")
  secondaryColor String      @default("#8b5cf6")
  textColor      String      @default("#1f2937")
  fontFamily     String      @default("Inter")
  layout         Layout      @default(CENTERED)
  buttonStyle    ButtonStyle @default(ROUNDED)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  profile        Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Link {
  id        String   @id @default(uuid())
  profileId String
  type      LinkType
  platform  String?
  title     String
  url       String
  icon      String?
  order     Int
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([order])
}

model Contact {
  id        String      @id @default(uuid())
  profileId String
  type      ContactType
  value     String
  label     String?
  order     Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model File {
  id           String   @id @default(uuid())
  profileId    String
  filename     String
  originalName String
  title        String
  fileUrl      String
  fileSize     Int
  mimeType     String
  order        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Popup {
  id              String   @id @default(uuid())
  profileId       String   @unique
  isEnabled       Boolean  @default(false)
  message         String
  duration        Int?
  backgroundColor String   @default("#3b82f6")
  textColor       String   @default("#ffffff")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum BackgroundType {
  COLOR
  IMAGE
}

enum ThemeMode {
  LIGHT
  DARK
}

enum Layout {
  CENTERED
  LEFT
  RIGHT
}

enum ButtonStyle {
  ROUNDED
  SQUARE
  PILL
}

enum LinkType {
  PLATFORM
  CUSTOM
}

enum ContactType {
  EMAIL
  PHONE
}
