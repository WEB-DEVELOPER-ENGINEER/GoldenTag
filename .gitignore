# Root level gitignore for Digital Profile Hub

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/

# Logs
logs/
*.log

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
temp/
tmp/
*.tmp

# Database
*.sqlite
*.sqlite3
*.db

# Uploads (user-generated content)
uploads/
!uploads/.gitkeep

# Testing
coverage/

# Misc
*.pid
.cache/
